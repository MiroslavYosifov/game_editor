{
  "name": "web-2d-game-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "tsx watch src/backend/server.ts",
    "build": "tsc --noEmit && vite build",
    "start": "tsx src/backend/server.ts"
  },
  "dependencies": {
    "pixi.js": "^7.4.2",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
